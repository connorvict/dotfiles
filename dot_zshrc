#Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
typeset -g POWERLEVEL9K_INSTANT_PROMPT=off

export LANG='en_US.UTF-8'
export LANGUAGE='en_US:en'
export LC_ALL='en_US.UTF-8'
export PATH="$HOME/.local/bin:$PATH"
export EDITOR='nvim'
export ZDOTDIR="$HOME/.config/zsh"
export COLORTERM='truecolor'
#GOLANG
export GOPATH="/usr/local/bin/go"
export PATH="$PATH:$GOPATH/bin"
#RUST
export PATH="$HOME/.cargo/bin:$PATH"
#FLY.io
export FLYCTL_INSTALL="/home/norconv/.fly"
export PATH="$FLYCTL_INSTALL/bin:$PATH"
# Turso
export PATH="/home/norconv/.turso:$PATH"
# Pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"
eval "$(pyenv virtualenv-init -)"

alias v.django="source $HOME/venv/django/bin/activate"


#CLI Tools
alias ls="exa"
alias ll="exa -alh"
alias tree="exa --tree --ignore-glob '.git|node_modules'"
alias cat="bat"
#Zoxide
eval "$(zoxide init zsh)"
alias cd="z"
alias zz="z -"
## Zellij completions
function zr () { zellij run --name "$*" -- zsh -ic "$*";}
function zrf () { zellij run --name "$*" --floating -- zsh -ic "$*";}
function ze () { zellij edit "$*";}
function zef () { zellij edit --floating "$*";}
function zj () { 
  if [ -n "$1" ]; then
    zellij --layout $HOME/.config/zellij/layouts/$1.kdl;
  else
    zellij;
  fi
}

if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
    source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi


# If antigen isn't installed, install it 
if [ ! -d ${ZDOTDIR:-~}/.antidote ]; then
  git clone --depth=1 https://github.com/mattmc3/antidote.git ${ZDOTDIR:-~}/.antidote
fi

# source antidote
autoload -Uz compinit && compinit
source ${ZDOTDIR:-~}/.antidote/antidote.zsh
source ${ZDOTDIR:-~}/.p10k.zsh

# initialize plugins statically with ${ZDOTDIR:-~}/.zsh_plugins.txt
antidote load

### Fix slowness of pastes with zsh-syntax-highlighting.zsh
pasteinit() {
  OLD_SELF_INSERT=${${(s.:.)widgets[self-insert]}[2,3]}
  zle -N self-insert url-quote-magic # I wonder if you'd need `.url-quote-magic`?
}

pastefinish() {
  zle -N self-insert $OLD_SELF_INSERT
}
zstyle :bracketed-paste-magic paste-init pasteinit
zstyle :bracketed-paste-magic paste-finish pastefinish
### Fix slowness of pastes

